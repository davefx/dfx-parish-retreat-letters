{
    "name": "davefx/dfx-parish-retreat-letters",
    "description": "A WordPress plugin for managing parish retreat letters with confidentiality and GDPR compliance",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "David Marín Carreño",
            "homepage": "https://davefx.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "yoast/phpunit-polyfills": "^1.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "DFX_Parish_Retreat_Letters\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DFX_Parish_Retreat_Letters\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit --configuration phpunit-basic.xml",
        "test:coverage": "./vendor/bin/phpunit --coverage-html coverage",
        "test:unit": "./vendor/bin/phpunit --testsuite unit",
        "test:integration": "./vendor/bin/phpunit --testsuite integration",
        "test:basic": "./vendor/bin/phpunit --configuration phpunit-basic.xml --testsuite basic",
        "test:comprehensive": "./vendor/bin/phpunit --configuration phpunit-basic.xml --testsuite comprehensive",
        "test:advanced": "./vendor/bin/phpunit --configuration phpunit-advanced.xml --testsuite advanced",
        "test:safe": "./vendor/bin/phpunit --configuration phpunit-basic.xml --testsuite comprehensive",
        "build": "./bin/build-dist.sh"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
