package-lock.json
TESTING.md

# Build and CI/CD
/bin
BUILD.md
validate-constraint-fixes.php
.distignore

# IDE and editor files
.vscode
.idea
.claude
*.swp
*.swo
.DS_Store
Thumbs.db

