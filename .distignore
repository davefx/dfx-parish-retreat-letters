# Distribution Ignore File
# Files and directories to exclude from distribution package

# Version control
.git
.gitignore
.gitattributes
.github

# Development and testing files
/tests
/node_modules

# Vendor: exclude dev dependencies, keep production ones (setasign/fpdf, setasign/fpdi)
/vendor/bin
/vendor/antecedent
/vendor/brain
/vendor/doctrine
/vendor/hamcrest
/vendor/mockery
/vendor/myclabs
/vendor/nikic
/vendor/phar-io
/vendor/phpunit
/vendor/sebastian
/vendor/theseer
/vendor/yoast
/vendor/tecnickcom/tcpdf/examples
/vendor/tecnickcom/tcpdf/tools
phpunit.xml
phpunit-basic.xml
phpunit-advanced.xml
.phpunit.result.cache
composer.json
composer.lock
package.json
package-lock.json
TESTING.md

# Build and CI/CD
/bin
BUILD.md
validate-constraint-fixes.php
.distignore

# IDE and editor files
.vscode
.idea
.claude
*.swp
*.swo
.DS_Store
Thumbs.db

# Temporary files
/tmp
/coverage

# Git conflict and temporary files
*.orig
*.rej
*~
*.bak
*.tmp
*.swn

# Documentation (optional - keep LICENSE and readme.txt)
# Uncomment if you don't want to include these in distribution
# /docs
