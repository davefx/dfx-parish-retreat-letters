#. Search and navigation messages for attendants
msgid "No attendants found for your search."
msgstr "No se encontraron asistentes para tu búsqueda."

msgid "No attendants found for this retreat."
msgstr "No se encontraron asistentes para este retiro."

msgid "Add the first attendant"
msgstr "Añadir el primer asistente"

msgid "Manage Attendants"
msgstr "Gestionar Asistentes"

msgid "Import CSV"
msgstr "Importar CSV"

msgid "Import Attendants from CSV"
msgstr "Importar Asistentes desde CSV"

msgid "CSV Import Instructions"
msgstr "Instrucciones de Importación CSV"

msgid "Your CSV file should have the following columns in this exact order:"
msgstr "Tu archivo CSV debe tener las siguientes columnas en este orden exacto:"

msgid "Date of Birth (YYYY-MM-DD format)"
msgstr "Fecha de Nacimiento (formato AAAA-MM-DD)"

msgid "The first row should contain column headers and will be skipped."
msgstr "La primera fila debe contener los encabezados de columna y será omitida."

msgid "CSV File"
msgstr "Archivo CSV"

msgid "Select a CSV file to import. Maximum file size: 2MB."
msgstr "Selecciona un archivo CSV para importar. Tamaño máximo de archivo: 2MB."

msgid "Import Attendants"
msgstr "Importar Asistentes"

msgid "Please select a valid CSV file."
msgstr "Por favor selecciona un archivo CSV válido."

msgid "CSV file is too large. Maximum size is 2MB."
msgstr "El archivo CSV es demasiado grande. El tamaño máximo es 2MB."

msgid "Unable to read CSV file."
msgstr "No se puede leer el archivo CSV."

msgid "Successfully imported %d attendants."
msgstr "%d asistentes importados con éxito."

msgid "%d rows had errors and were not imported."
msgstr "%d filas tuvieron errores y no fueron importadas."

#. Confirmation messages for attendants
msgid "Are you sure you want to delete this attendant?"
msgstr "¿Estás seguro de que quieres eliminar este asistente?"

#. New CSV Import strings
msgid "CSV file appears to be empty or invalid."
msgstr "El archivo CSV parece estar vacío o no es válido."

msgid "Required fields missing from CSV: %s"
msgstr "Faltan campos requeridos en el CSV: %s"

msgid "Line %d: Invalid data format"
msgstr "Línea %d: Formato de datos inválido"

msgid "Line %d: Failed to create attendant"
msgstr "Línea %d: Error al crear asistente"

msgid "Error details:"
msgstr "Detalles del error:"

msgid "...and more errors."
msgstr "...y más errores."

msgid "Your CSV file should contain the following required columns. Column order is flexible and the system will automatically identify columns by their names:"
msgstr "Tu archivo CSV debe contener las siguientes columnas requeridas. El orden de las columnas es flexible y el sistema identificará automáticamente las columnas por sus nombres:"

msgid "(or \"Nombre\")"
msgstr "(o \"Nombre\")"

msgid "(or \"Apellidos\")"
msgstr "(o \"Apellidos\")"

msgid "(or \"Fecha de Nacimiento\")"
msgstr "(o \"Fecha de Nacimiento\")"

msgid "(or \"Nombre del Contacto de Emergencia\")"
msgstr "(o \"Nombre del Contacto de Emergencia\")"

msgid "(or \"Apellido del Contacto de Emergencia\")"
msgstr "(o \"Apellido del Contacto de Emergencia\")"

msgid "(or \"Teléfono del Contacto de Emergencia\")"
msgstr "(o \"Teléfono del Contacto de Emergencia\")"

msgid "Additional features:"
msgstr "Características adicionales:"

msgid "Column order can be any order"
msgstr "Las columnas pueden estar en cualquier orden"

msgid "Extra columns are allowed and will be ignored"
msgstr "Se permiten columnas adicionales y serán ignoradas"

msgid "Date formats supported: YYYY-MM-DD, DD/MM/YYYY, MM/DD/YYYY, DD-MM-YYYY, MM-DD-YYYY, DD.MM.YYYY"
msgstr "Formatos de fecha soportados: AAAA-MM-DD, DD/MM/AAAA, MM/DD/AAAA, DD-MM-AAAA, MM-DD-AAAA, DD.MM.AAAA"

msgid "Column names can be in English or Spanish"
msgstr "Los nombres de las columnas pueden estar en inglés o español"

msgid "The first row must contain column headers"
msgstr "La primera fila debe contener los encabezados de las columnas"

msgid "Date Format Preference"
msgstr "Preferencia de Formato de Fecha"

msgid "DD/MM/YYYY (Day/Month/Year)"
msgstr "DD/MM/AAAA (Día/Mes/Año)"

msgid "MM/DD/YYYY (Month/Day/Year)"
msgstr "MM/DD/AAAA (Mes/Día/Año)"

msgid "This preference is used to interpret ambiguous dates like \"01/10/2025\". Unambiguous dates are always parsed correctly regardless of this setting."
msgstr "Esta preferencia se utiliza para interpretar fechas ambiguas como \"01/10/2025\". Las fechas no ambiguas siempre se analizan correctamente independientemente de esta configuración."

msgid "Important Note about Date Formats:"
msgstr "Nota Importante sobre Formatos de Fecha:"

msgid "For ambiguous dates like \"01/10/2025\", the system cannot determine if this means \"January 10th\" or \"October 1st\". To avoid confusion:"
msgstr "Para fechas ambiguas como \"01/10/2025\", el sistema no puede determinar si esto significa \"10 de enero\" o \"1 de octubre\". Para evitar confusión:"

msgid "Use unambiguous formats like YYYY-MM-DD (2025-01-10)"
msgstr "Use formatos no ambiguos como AAAA-MM-DD (2025-01-10)"

msgid "Set your preferred date format below to ensure consistent interpretation"
msgstr "Configure su formato de fecha preferido abajo para asegurar una interpretación consistente"

#, php-format
msgid "Warning: %1$d ambiguous date(s) were interpreted using your current preference (%2$s)."
msgstr "Advertencia: %1$d fecha(s) ambigua(s) fueron interpretadas usando su preferencia actual (%2$s)."

msgid "Ambiguous dates found:"
msgstr "Fechas ambiguas encontradas:"

msgid "To avoid ambiguity in future imports, consider using YYYY-MM-DD format."
msgstr "Para evitar ambigüedad en futuras importaciones, considere usar el formato AAAA-MM-DD."

#. Message system translations
msgid "Send a Confidential Message"
msgstr "Enviar un Mensaje Confidencial"

msgid "For Retreat Attendant"
msgstr "Para el Asistente del Retiro"

msgid "Your Name (Optional)"
msgstr "Su Nombre (Opcional)"

msgid "Enter your name if you wish to identify yourself"
msgstr "Ingrese su nombre si desea identificarse"

msgid "Your Message"
msgstr "Su Mensaje"

msgid "Write your confidential message here..."
msgstr "Escriba su mensaje confidencial aquí..."

msgid "Bold"
msgstr "Negrita"

msgid "Italic"
msgstr "Cursiva"

msgid "Underline"
msgstr "Subrayado"

msgid "You can use the toolbar to format your text. HTML is allowed but will be filtered for security."
msgstr "Puede usar la barra de herramientas para formatear su texto. HTML está permitido pero será filtrado por seguridad."

msgid "Attach Files (Optional)"
msgstr "Adjuntar Archivos (Opcional)"

msgid "Allowed file types: PDF, DOC, DOCX, TXT, JPG, PNG, GIF. Maximum 5MB per file."
msgstr "Tipos de archivo permitidos: PDF, DOC, DOCX, TXT, JPG, PNG, GIF. Máximo 5MB por archivo."

msgid "Security Check"
msgstr "Verificación de Seguridad"

msgid "Send Confidential Message"
msgstr "Enviar Mensaje Confidencial"

msgid "Sending..."
msgstr "Enviando..."

msgid "Privacy & Security"
msgstr "Privacidad y Seguridad"

msgid "Your message will be encrypted and stored securely."
msgstr "Su mensaje será cifrado y almacenado de forma segura."

msgid "Only authorized retreat administrators can access your message."
msgstr "Solo los administradores autorizados del retiro pueden acceder a su mensaje."

msgid "Messages can only be viewed when printed - no content is displayed on screen."
msgstr "Los mensajes solo se pueden ver cuando se imprimen - no se muestra contenido en pantalla."

msgid "Your IP address will be anonymized after 30 days for privacy compliance."
msgstr "Su dirección IP será anonimizada después de 30 días para cumplir con la privacidad."

msgid "All data is handled in accordance with GDPR and Spanish privacy laws."
msgstr "Todos los datos se manejan de acuerdo con el GDPR y las leyes de privacidad españolas."

msgid "Please solve: "
msgstr "Por favor resuelva: "

msgid "Remove"
msgstr "Eliminar"

msgid "Incorrect security answer. Please try again."
msgstr "Respuesta de seguridad incorrecta. Por favor inténtelo de nuevo."

msgid "Your message has been sent successfully and securely stored."
msgstr "Su mensaje ha sido enviado exitosamente y almacenado de forma segura."

msgid "An error occurred while sending your message."
msgstr "Ocurrió un error al enviar su mensaje."

msgid "A network error occurred. Please try again."
msgstr "Ocurrió un error de red. Por favor inténtelo de nuevo."

msgid "Security check failed."
msgstr "Falló la verificación de seguridad."

msgid "Too many submission attempts. Please wait before trying again."
msgstr "Demasiados intentos de envío. Por favor espere antes de intentar de nuevo."

msgid "Please complete the security check."
msgstr "Por favor complete la verificación de seguridad."

msgid "Incorrect security answer."
msgstr "Respuesta de seguridad incorrecta."

msgid "Invalid attendant."
msgstr "Asistente inválido."

msgid "Message content is required."
msgstr "El contenido del mensaje es requerido."

msgid "Failed to save message."
msgstr "Error al guardar el mensaje."

msgid "Message sent successfully."
msgstr "Mensaje enviado exitosamente."

msgid "Too many requests. Please wait before trying again."
msgstr "Demasiadas solicitudes. Por favor espere antes de intentar de nuevo."

msgid "Rate Limit Exceeded"
msgstr "Límite de Velocidad Excedido"

