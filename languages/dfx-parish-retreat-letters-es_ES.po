#: includes/class-dfx-parish-retreat-letters.php:1448
msgid "Please complete the security check."
msgstr "Por favor complete la verificación de seguridad."

#: includes/class-dfx-parish-retreat-letters.php:1453
msgid "Incorrect security answer."
msgstr "Respuesta de seguridad incorrecta."

#: includes/class-dfx-parish-retreat-letters.php:1459
msgid "Invalid attendant."
