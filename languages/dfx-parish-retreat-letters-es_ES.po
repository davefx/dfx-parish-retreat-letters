msgstr "Tu mensaje será cifrado y almacenado de forma segura."

#: includes/class-dfx-parish-retreat-letters.php:629
msgid "Only authorized retreat administrators can access your message."
msgstr "Solo los administradores autorizados del retiro pueden acceder a tu mensaje."

