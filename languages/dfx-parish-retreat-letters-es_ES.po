#: includes/class-admin.php:3548
msgid "(or \"Apellidos\")"
msgstr "(o \"Apellidos\")"

#: includes/class-admin.php:3549
msgid "(or \"Fecha de Nacimiento\")"
msgstr "(o \"Fecha de Nacimiento\")"

#: includes/class-admin.php:3550
msgid "(or \"Nombre del Contacto de Emergencia\")"
msgstr "(o \"Nombre del Contacto de Emergencia\")"

#: includes/class-admin.php:3551
msgid "(or \"Apellido del Contacto de Emergencia\")"
msgstr "(o \"Apellido del Contacto de Emergencia\")"

#: includes/class-admin.php:3552
msgid "(or \"Teléfono del Contacto de Emergencia\")"
msgstr "(o \"Teléfono del Contacto de Emergencia\")"

#: includes/class-admin.php:3555
msgid "Additional features:"
msgstr "Características adicionales:"

#: includes/class-admin.php:3557
msgid "Column order can be any order"
msgstr "Las columnas pueden estar en cualquier orden"

#: includes/class-admin.php:3558
msgid "Extra columns are allowed and will be ignored"
msgstr "Se permiten columnas adicionales y serán ignoradas"

#: includes/class-admin.php:3559
msgid "Date formats supported: YYYY-MM-DD, DD/MM/YYYY, MM/DD/YYYY, DD-MM-YYYY, MM-DD-YYYY, DD.MM.YYYY"
msgstr "Formatos de fecha soportados: AAAA-MM-DD, DD/MM/AAAA, MM/DD/AAAA, DD-MM-AAAA, MM-DD-AAAA, DD.MM.AAAA"

#: includes/class-admin.php:3560
msgid "Column names can be in English or Spanish"
msgstr "Los nombres de las columnas pueden estar en inglés o español"

#: includes/class-admin.php:3561
msgid "The first row must contain column headers"
msgstr "La primera fila debe contener los encabezados de las columnas"

#: includes/class-admin.php:3579
msgid "Date Format Preference"
msgstr "Preferencia de Formato de Fecha"

#: includes/class-admin.php:2709
#: includes/class-admin.php:2715
#: includes/class-admin.php:3584
msgid "DD/MM/YYYY (Day/Month/Year)"
msgstr "DD/MM/AAAA (Día/Mes/Año)"

#: includes/class-admin.php:2712
#: includes/class-admin.php:3585
msgid "MM/DD/YYYY (Month/Day/Year)"
msgstr "MM/DD/AAAA (Mes/Día/Año)"

#: includes/class-admin.php:3588
msgid "This preference is used to interpret ambiguous dates like \"01/10/2025\". Unambiguous dates are always parsed correctly regardless of this setting."
msgstr "Esta preferencia se utiliza para interpretar fechas ambiguas como \"01/10/2025\". Las fechas no ambiguas siempre se analizan correctamente independientemente de esta configuración."

#: includes/class-admin.php:3564
msgid "Important Note about Date Formats:"
msgstr "Nota Importante sobre Formatos de Fecha:"

#: includes/class-admin.php:3565
msgid "For ambiguous dates like \"01/10/2025\", the system cannot determine if this means \"January 10th\" or \"October 1st\". To avoid confusion:"
msgstr "Para fechas ambiguas como \"01/10/2025\", el sistema no puede determinar si esto significa \"10 de enero\" o \"1 de octubre\". Para evitar confusión:"

#: includes/class-admin.php:3567
msgid "Use unambiguous formats like YYYY-MM-DD (2025-01-10)"
msgstr "Usa formatos no ambiguos como AAAA-MM-DD (2025-01-10)"

#: includes/class-admin.php:3568
msgid "Set your preferred date format below to ensure consistent interpretation"
msgstr "Configura el formato de fecha preferido abajo para asegurar una interpretación consistente"

#. translators: %1$d: Number of ambiguous dates, %2$s: Current preference
#: includes/class-admin.php:2721
#, php-format
msgid "Warning: %1$d ambiguous date(s) were interpreted using your current preference (%2$s)."
msgstr "Advertencia: %1$d fecha(s) ambigua(s) fueron interpretadas usando la preferencia actual (%2$s)."

#: includes/class-admin.php:2727
msgid "Ambiguous dates found:"
msgstr "Fechas ambiguas encontradas:"

#: includes/class-admin.php:2730
msgid "To avoid ambiguity in future imports, consider using YYYY-MM-DD format."
msgstr "Para evitar ambigüedad en futuras importaciones, considere usar el formato AAAA-MM-DD."

#: includes/class-dfx-parish-retreat-letters.php:603
msgid "Send a Confidential Message"
msgstr "Enviar un Mensaje Confidencial"

#: includes/class-dfx-parish-retreat-letters.php:606
msgid "For Retreat Attendant"
msgstr "Para el Asistente del Retiro"

#: includes/class-dfx-parish-retreat-letters.php:645
msgid "Your Message"
msgstr "Tu Mensaje"

#: includes/class-dfx-parish-retreat-letters.php:656
msgid "Write your confidential message here..."
msgstr "Escribe tu mensaje confidencial aquí..."

#: includes/class-dfx-parish-retreat-letters.php:648
msgid "Bold"
msgstr "Negrita"

#: includes/class-dfx-parish-retreat-letters.php:649
msgid "Italic"
msgstr "Cursiva"

#: includes/class-dfx-parish-retreat-letters.php:650
msgid "Underline"
msgstr "Subrayado"

#: includes/class-dfx-parish-retreat-letters.php:659
msgid "You can use the toolbar to format your text, create lists, and paste images. HTML is allowed but will be filtered for security."
msgstr "Puedes usar la barra de herramientas para formatear tu texto, crear listas y pegar imágenes. HTML está permitido pero será filtrado por seguridad."

#: includes/class-dfx-parish-retreat-letters.php:682
msgid "Security Check"
msgstr "Verificación de Seguridad"

#: includes/class-dfx-parish-retreat-letters.php:714
msgid "Send Confidential Message"
msgstr "Enviar Mensaje Confidencial"

#: includes/class-dfx-parish-retreat-letters.php:716
msgid "Sending..."
msgstr "Enviando..."

#: includes/class-dfx-parish-retreat-letters.php:723
msgid "Privacy & Security"
msgstr "Privacidad y Seguridad"

#: includes/class-dfx-parish-retreat-letters.php:725
msgid "Your message will be encrypted and stored securely."
msgstr "Tu mensaje será cifrado y almacenado de forma segura."

#: includes/class-dfx-parish-retreat-letters.php:726
msgid "Only authorized retreat administrators can access your message."
msgstr "Solo los administradores autorizados del retiro pueden acceder a tu mensaje."

#: includes/class-dfx-parish-retreat-letters.php:727
msgid "Messages can only be viewed when printed - no content is displayed on screen."
msgstr "Los mensajes solo se pueden ver cuando se imprimen - no se muestra contenido en pantalla."

#: includes/class-dfx-parish-retreat-letters.php:728
msgid "Your IP address will be anonymized after 30 days for privacy compliance."
msgstr "Tu dirección IP será anonimizada después de 30 días para cumplir con la privacidad."

#: includes/class-dfx-parish-retreat-letters.php:729
msgid "All data is handled in accordance with GDPR and Spanish privacy laws."
msgstr "Todos los datos se manejan de acuerdo con el RGPD y las leyes de privacidad españolas."

#: includes/class-dfx-parish-retreat-letters.php:1529
msgid "Please solve: "
msgstr "Por favor resuelve: "

#: includes/class-dfx-parish-retreat-letters.php:1564
msgid "Remove"
msgstr "Eliminar"

#: includes/class-dfx-parish-retreat-letters.php:1639
msgid "Incorrect security answer. Please try again."
msgstr "Respuesta de seguridad incorrecta. Por favor inténtelo de nuevo."

#: includes/class-dfx-parish-retreat-letters.php:1674
msgid "Your message has been sent successfully and securely stored."
msgstr "Tu mensaje ha sido enviado exitosamente y almacenado de forma segura."

#: includes/class-dfx-parish-retreat-letters.php:1679
msgid "An error occurred while sending your message."
msgstr "Ocurrió un error al enviar el mensaje."

#: includes/class-admin.php:4714
#: includes/class-admin.php:4740
#: includes/class-dfx-parish-retreat-letters.php:1695
msgid "A network error occurred. Please try again."
msgstr "Ocurrió un error de red. Por favor inténtelo de nuevo."

#: includes/class-dfx-parish-retreat-letters.php:1699
msgid "The request timed out. Please check your connection and try again."
msgstr "La solicitud ha expirado. Por favor revise su conexión e inténtelo de nuevo."

#: includes/class-dfx-parish-retreat-letters.php:1702
msgid "Cannot connect to the server. Please check your internet connection."
msgstr "No se puede conectar al servidor. Por favor revise su conexión a internet."

#: includes/class-dfx-parish-retreat-letters.php:1704
msgid "Access denied. Please refresh the page and try again."
msgstr "Acceso denegado. Por favor actualice la página e inténtelo de nuevo."

#: includes/class-dfx-parish-retreat-letters.php:1706
msgid "The uploaded files are too large. Please reduce the file size and try again."
msgstr "Los archivos subidos son demasiado grandes. Por favor reduzca el tamaño de los archivos e inténtelo de nuevo."

