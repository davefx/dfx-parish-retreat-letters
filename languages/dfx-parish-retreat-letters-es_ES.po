msgstr "El contenido del archivo está cifrado y no puede ser exportado por razones de seguridad."

msgid "Please provide an identifier (name or email)."
msgstr "Por favor proporcione un identificador (nombre o correo electrónico)."

msgid "Please type \"ERASE\" to confirm data deletion."
msgstr "Por favor escriba \"BORRAR\" para confirmar la eliminación de datos."

