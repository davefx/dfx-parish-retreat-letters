msgid "DFX Parish Retreat Letters: OpenSSL extension is required for the confidential message system."
msgstr "DFX Cartas de Retiro Parroquial: La extensión OpenSSL es requerida para el sistema de mensajes confidenciales."
msgstr "Para evitar ambigüedad en futuras importaciones, considere usar el formato AAAA-MM-DD."